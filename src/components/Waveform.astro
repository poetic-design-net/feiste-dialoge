---
interface Props {
  className?: string;
  animate?: boolean;
  tone?: 'light' | 'dark';
  density?: 'normal' | 'sparse';
}

const {
  className = '',
  animate = false,
  tone = 'light',
  density = 'normal',
} = Astro.props;

const count = density === 'sparse' ? 48 : 96;

// Deterministic pseudo-random for consistent SSR output
const bars = Array.from({ length: count }, (_, i) => {
  const t = i / count;
  const wave =
    Math.sin(i * 0.35) * 0.35 +
    Math.sin(i * 0.11 + 1.2) * 0.25 +
    Math.sin(i * 0.7 + 2.1) * 0.15 +
    Math.sin(i * 0.22 + 0.5) * 0.2;
  const envelope = Math.sin(t * Math.PI) * 0.6 + 0.4;
  const base = Math.abs(wave) * envelope;
  const height = Math.max(6, Math.min(100, base * 120 + 10));
  const accent = i % 11 === 0;
  return { height, accent, delay: (i * 35) % 2400 };
});

const toneClasses = {
  light: 'waveform-light',
  dark: 'waveform-dark',
} as const;
---

<div class={`waveform-wrap ${toneClasses[tone]} ${animate ? 'waveform-animate' : ''} ${className}`}>
  <div class="waveform-bars" aria-hidden="true">
    {bars.map((bar) => (
      <span
        class:list={['waveform-bar', bar.accent && 'is-accent']}
        style={`--h: ${bar.height}%; --d: ${bar.delay}ms;`}
      ></span>
    ))}
  </div>
  <div class="waveform-playhead" aria-hidden="true"></div>
</div>

<style>
  .waveform-wrap {
    position: relative;
    width: 100%;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: center;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  .waveform-bars {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    height: 100%;
    gap: 2px;
  }

  .waveform-bar {
    flex: 1;
    height: var(--h);
    max-width: 3px;
    min-width: 1.5px;
    border-radius: 999px;
    background: currentColor;
    opacity: 0.35;
    transform-origin: center;
    transition:
      height 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.4s ease,
      background-color 0.4s ease;
  }
  .waveform-bar.is-accent {
    opacity: 0.8;
  }

  .waveform-light {
    color: #94a864;
  }
  .waveform-dark {
    color: rgba(242, 241, 232, 0.55);
  }
  .waveform-dark .waveform-bar.is-accent {
    color: #bacf87;
    opacity: 1;
  }

  .waveform-playhead {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 10%;
    width: 1px;
    background: currentColor;
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .waveform-animate .waveform-bar {
      animation: waveform-pulse 3.6s ease-in-out infinite;
      animation-delay: var(--d);
    }
    .waveform-animate .waveform-playhead {
      opacity: 0.35;
      animation: playhead-sweep 10s linear infinite;
    }
  }

  @keyframes waveform-pulse {
    0%, 100% { height: var(--h); opacity: 0.35; }
    50% { height: calc(var(--h) * 0.6); opacity: 0.55; }
  }
  .waveform-animate .waveform-bar.is-accent {
    animation-duration: 2.2s;
  }

  @keyframes playhead-sweep {
    0%   { left: 6%;  opacity: 0; }
    8%   { opacity: 0.4; }
    92%  { opacity: 0.4; }
    100% { left: 94%; opacity: 0; }
  }
</style>
