---
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
import { getEntry } from 'astro:content';
import '@/styles/global.css';

interface SEO {
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: string;
  noindex?: boolean;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  active?: 'home' | 'portfolio' | 'about' | 'contact';
  noindex?: boolean;
  seo?: SEO | null;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image,
  active,
  noindex = false,
  seo,
  jsonLd,
} = Astro.props;

const site = await getEntry('settings', 'site');
const siteName = site?.data.siteName ?? 'Feiste Dialoge';
const siteDescription =
  site?.data.description ??
  'Dialogbuch, Dramaturgie und Synchronregie von Florian Feiste.';
const defaultOgImage = site?.data.defaultOgImage ?? '/og-image.png';

// Resolve final SEO values (per-page seo overrides props, props override site defaults)
const finalTitle = seo?.metaTitle ?? title;
const finalDescription = seo?.metaDescription ?? description ?? siteDescription;
const finalNoindex = seo?.noindex ?? noindex;

const pageTitle = finalTitle.includes(siteName)
  ? finalTitle
  : `${finalTitle} | ${siteName}`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Image fallback: explicit seo.ogImage > passed image > default OG > dynamic /api/og
const explicitImage = seo?.ogImage ?? image ?? site?.data.defaultOgImage;
const dynamicOgParams = new URLSearchParams({
  title: finalTitle,
  subtitle: finalDescription.slice(0, 140),
});
const dynamicOg = `/api/og?${dynamicOgParams.toString()}`;

const finalImage = explicitImage ?? dynamicOg;
const ogImageUrl = finalImage.startsWith('http')
  ? finalImage
  : new URL(finalImage, Astro.site).toString();

// Default structured data (WebSite + Person from settings)
const baseJsonLd: Record<string, unknown>[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: Astro.site?.toString(),
    description: siteDescription,
  },
];

if (site?.data.personName) {
  baseJsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: site.data.personName,
    jobTitle: site.data.personJobTitle ?? undefined,
    url: Astro.site?.toString(),
    email: site.data.contactEmail ?? undefined,
    telephone: site.data.contactPhone ?? undefined,
    sameAs: site.data.sameAs.length > 0 ? site.data.sameAs : undefined,
  });
}

const pageJsonLd = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [];

const allJsonLd = [...baseJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonicalURL} />
    {finalNoindex && <meta name="robots" content="noindex,nofollow" />}
    {site?.data.googleSiteVerification && (
      <meta
        name="google-site-verification"
        content={site.data.googleSiteVerification}
      />
    )}

    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="de_DE" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&family=Inter:wght@300;400;500;600;700;800&family=Permanent+Marker&family=Caveat:wght@400;700&display=swap"
      rel="stylesheet"
    />

    {allJsonLd.map((schema) => (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(schema, (_, v) => (v === undefined ? undefined : v))}
      />
    ))}

    <ClientRouter />
  </head>

  <body class="min-h-screen flex flex-col pt-20 md:pt-24">
    <Header active={active} />
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <Footer />

    <script is:inline>
      (function () {
        const initReveal = () => {
          const els = document.querySelectorAll('.reveal, .reveal-stagger');
          if (!els.length) return;
          if (!('IntersectionObserver' in window)) {
            els.forEach((el) => el.classList.add('is-visible'));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
          );
          els.forEach((el) => io.observe(el));
        };
        initReveal();
        document.addEventListener('astro:page-load', initReveal);
      })();
    </script>
  </body>
</html>
