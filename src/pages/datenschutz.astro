---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Datenschutz" description="Datenschutzerklärung nach DSGVO." noindex>
  <div class="container-main py-16 md:py-24 max-w-3xl">
    <h1 class="font-headline text-4xl md:text-5xl font-bold mb-10">Datenschutz</h1>

    <div class="prose prose-stone max-w-none font-body">
      <p class="italic text-on-surface-variant">
        Platzhalter für die Datenschutzerklärung. Bitte durch eine rechtssicher formulierte Version ersetzen (z. B. aus einem Generator oder von einem Fachanwalt).
      </p>

      <h2>Kontakt</h2>
      <p>Bei Fragen zum Datenschutz wenden Sie sich an <a href="mailto:kontakt@feiste-dialoge.de">kontakt@feiste-dialoge.de</a>.</p>
    </div>
  </div>
</BaseLayout>
