---
import BaseLayout from '@layouts/BaseLayout.astro';
import Waveform from '@components/Waveform.astro';
import Icon from '@components/Icon.astro';
import SmartImage from '@components/SmartImage.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import ProjectGallery from '@components/ProjectGallery.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();
const data = project.data;

const metaRows: Array<[string, string | undefined]> = [
  ['Jahr', data.year],
  ['Genre', data.genre],
  ['Studio', data.studio],
  ['Produktion', data.production],
  ['Sprachfassung', data.language],
  ['Synchron-Art', data.syncType],
];

const projectJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: data.title,
  headline: data.subtitle,
  description: data.description,
  dateCreated: data.year,
  genre: data.genre,
  inLanguage: 'de',
  creator: {
    '@type': 'Person',
    name: 'Florian Feiste',
  },
  ...(data.studio && {
    producer: { '@type': 'Organization', name: data.studio },
  }),
  ...(data.heroImage && { image: data.heroImage }),
};

// Dynamic OG fallback if no explicit image set
const ogParams = new URLSearchParams({
  eyebrow: `${data.role} · ${data.year}`,
  title: data.title,
  subtitle: data.subtitle ?? data.description.slice(0, 140),
  meta: data.genre ?? '',
});
const dynamicProjectOg = `/api/og?${ogParams.toString()}`;
const heroOgImage = data.seo?.ogImage ?? data.heroImage ?? dynamicProjectOg;
---

<BaseLayout
  title={data.title}
  description={data.seo?.metaDescription ?? data.seoDescription ?? data.description.slice(0, 160)}
  image={heroOgImage}
  active="portfolio"
  seo={data.seo}
  jsonLd={projectJsonLd}
>
  <div class="container-main py-8 md:py-12">
    <Breadcrumbs
      class="mb-8"
      items={[
        { label: 'Start', href: '/' },
        { label: 'Portfolio', href: '/portfolio/' },
        { label: data.title },
      ]}
    />

    {/* Hero */}
    <header class="mb-12 md:mb-16">
      <div class="relative w-full min-h-[320px] md:h-[450px] rounded-xl overflow-hidden bg-primary">
        {data.heroImage && (
          <SmartImage
            src={data.heroImage}
            alt={data.heroImageAlt ?? data.title}
            class="w-full h-full object-cover absolute inset-0"
            sizes="(min-width: 1200px) 1200px, 100vw"
            width={1600}
            height={900}
            priority
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-on-surface/80 via-on-surface/30 to-transparent"></div>
        <div class="relative z-10 flex flex-col justify-end h-full p-8 md:p-12 min-h-[320px] md:min-h-[450px]">
          <span class="font-headline text-sm uppercase tracking-widest text-primary-fixed-dim mb-3 inline-block">
            {data.role} · {data.year}
          </span>
          <h1 class="font-headline text-4xl md:text-5xl font-bold text-inverse-on-surface mb-3 tracking-tight">
            {data.title}
          </h1>
          {data.subtitle && (
            <p class="text-inverse-on-surface/90 text-lg md:text-xl font-light tracking-wide max-w-2xl">
              {data.subtitle}
            </p>
          )}
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-start">
      {/* Sidebar: Meta + Description */}
      <aside class="lg:col-span-4 space-y-8 lg:sticky lg:top-32">
        <section class="bg-surface-container-low p-8 rounded-lg">
          <h2 class="font-headline text-2xl text-primary mb-6">Details</h2>
          <dl class="space-y-5">
            {metaRows.filter(([, v]) => v).map(([label, value], i, arr) => (
              <div class:list={[
                'flex flex-col gap-1',
                i < arr.length - 1 || data.services.length > 0 ? 'border-b border-outline-variant/30 pb-4' : '',
              ]}>
                <dt class="text-xs uppercase tracking-widest text-on-surface-variant font-bold">
                  {label}
                </dt>
                <dd class="text-base md:text-lg font-medium">{value}</dd>
              </div>
            ))}
            {data.services.length > 0 && (
              <div class="flex flex-col gap-2">
                <dt class="text-xs uppercase tracking-widest text-on-surface-variant font-bold">Leistung</dt>
                <dd class="flex flex-wrap gap-2 mt-1">
                  {data.services.map((s) => <span class="chip">{s}</span>)}
                </dd>
              </div>
            )}
          </dl>
        </section>

        <section class="bg-surface-container-highest p-8 rounded-lg">
          <h3 class="font-headline text-xl text-on-background mb-4">Projektbeschreibung</h3>
          <div class="text-on-surface-variant leading-relaxed text-sm space-y-4 whitespace-pre-line">
            {data.description}
          </div>
        </section>

        <section class="bg-primary p-8 rounded-lg text-on-primary">
          <p class="font-headline text-lg font-bold mb-6 leading-tight">
            Sollen wir auch für Ihr nächstes Projekt die richtigen Worte finden?
          </p>
          <a
            href="/kontakt/"
            class="inline-flex items-center justify-center gap-2 w-full bg-surface-container-lowest text-primary hover:bg-surface-container-high transition-colors px-6 py-3 rounded font-headline text-sm font-bold"
          >
            Dialog starten
            <Icon name="arrow_forward" size={20} />
          </a>
        </section>
      </aside>

      {/* Main: Markdown content + Videos */}
      <section class="lg:col-span-8 lg:ml-4 space-y-8">
        <div class="bg-surface-container-lowest rounded-lg p-8 md:p-12">
          <div class="prose prose-stone max-w-none font-body prose-headings:font-headline prose-headings:text-on-surface">
            <Content />
          </div>
        </div>

        {data.videos.length > 0 && (
          <div class="bg-surface-container-lowest rounded-lg p-8 md:p-12">
            <header class="mb-8 space-y-2">
              <p class="font-headline text-sm uppercase tracking-widest text-primary">Arbeitsbeispiele</p>
              <h2 class="font-headline text-2xl md:text-3xl text-on-surface font-bold">
                {data.videos.length === 1 ? 'Ausschnitt ansehen' : 'Ausschnitte ansehen'}
              </h2>
            </header>
            <div class="flex flex-wrap gap-6">
              {data.videos.map((video) => {
                const isInstagram = video.url?.includes('instagram.com');
                const isExternal = video.url?.startsWith('http');
                const Wrapper = video.url ? 'a' : 'article';
                return (
                  <Wrapper
                    href={video.url}
                    target={isExternal ? '_blank' : undefined}
                    rel={isExternal ? 'noopener noreferrer' : undefined}
                    class="group block flex-1 min-w-[220px] max-w-[280px]"
                  >
                    <div class="aspect-[4/5] bg-surface-container-highest rounded-xl overflow-hidden relative mb-4 shadow-sm">
                      {video.thumbnail ? (
                        <SmartImage
                          src={video.thumbnail}
                          alt={video.thumbnailAlt ?? video.title}
                          class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500 group-hover:brightness-75"
                          sizes="280px"
                          width={480}
                          height={600}
                        />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-primary/15 via-surface-container-high to-secondary-container/30"></div>
                      )}
                      <div class="absolute inset-0 flex items-center justify-center">
                        <div class="w-14 h-14 md:w-16 md:h-16 bg-primary/95 text-on-primary rounded-full flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform duration-500">
                          <Icon name="play_arrow" size={30} />
                        </div>
                      </div>
                      {isInstagram && (
                        <div class="absolute top-3 right-3 w-8 h-8 bg-on-surface/70 backdrop-blur-sm text-inverse-on-surface rounded-full flex items-center justify-center">
                          <Icon name="instagram" size={16} />
                        </div>
                      )}
                    </div>
                    <h3 class="font-headline text-lg font-bold group-hover:text-primary transition-colors leading-tight">
                      {video.title}
                    </h3>
                    {video.subtitle && (
                      <p class="text-xs mt-1 tracking-wide text-on-surface-variant">{video.subtitle}</p>
                    )}
                    {isInstagram && (
                      <p class="text-xs mt-2 font-label uppercase tracking-widest text-primary inline-flex items-center gap-1">
                        Auf Instagram ansehen
                        <Icon name="open_in_new" size={12} />
                      </p>
                    )}
                  </Wrapper>
                );
              })}
            </div>
          </div>
        )}
      </section>
    </div>

    {/* Waveform divider */}
    <div class="my-16 md:my-24">
      <Waveform animate />
    </div>

    {/* Gallery */}
    {data.gallery.length > 0 && (
      <ProjectGallery items={data.gallery} />
    )}
  </div>
</BaseLayout>
