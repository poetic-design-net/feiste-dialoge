---
import BaseLayout from '@layouts/BaseLayout.astro';
import Icon from '@components/Icon.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import SmartImage from '@components/SmartImage.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => Number(b.data.year) - Number(a.data.year) || a.data.order - b.data.order
);

const highlights = allProjects.filter((p) => p.data.highlight).slice(0, 3);

const statusStyles: Record<string, string> = {
  'veröffentlicht': 'text-outline',
  'in-produktion': 'text-primary',
  'abgeschlossen': 'text-primary-container',
};

const statusLabel: Record<string, string> = {
  'veröffentlicht': 'Veröffentlicht',
  'in-produktion': 'In Produktion',
  'abgeschlossen': 'Abgeschlossen',
};
---

<BaseLayout
  title="Filmografie & Projekt-Galerie"
  description="Kuratierte Sammlung filmischer Dialoge, Drehbücher und kreativer Visionen der letzten Jahre."
  active="portfolio"
>
  <div class="container-main py-16 md:py-24">
    <Breadcrumbs
      class="mb-10"
      items={[
        { label: 'Start', href: '/' },
        { label: 'Portfolio' },
      ]}
    />

    <!-- Hero -->
    <section class="mb-16 md:mb-20">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-end">
        <div class="md:col-span-8 space-y-4">
          <span class="font-headline text-primary uppercase tracking-[0.2em] text-sm">
            Archiv der Narrative
          </span>
          <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-none text-on-surface">
            Filmografie &<br/>Projekt-Galerie
          </h1>
        </div>
        <div class="md:col-span-4 pb-2">
          <p class="text-on-surface-variant leading-relaxed text-lg italic">
            Eine kuratierte Sammlung filmischer Dialoge, Drehbücher und kreativer Visionen der letzten Jahre.
          </p>
        </div>
      </div>
    </section>

    {/* Highlights */}
    {highlights.length > 0 && (
      <section class="mb-16 md:mb-20">
        <div class="flex items-end justify-between mb-8 reveal">
          <h2 class="font-headline text-2xl md:text-3xl font-bold text-on-surface">
            Highlights
          </h2>
          <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">
            {highlights.length} ausgewählte Arbeiten
          </span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-stagger">
          {highlights.map((project) => (
            <a
              href={`/portfolio/${project.slug}/`}
              class="group relative bg-surface-container-lowest rounded-lg shadow-sm hover:shadow-ambient transition-all duration-500 flex flex-col overflow-hidden"
            >
              <div class="aspect-[3/4] relative overflow-hidden bg-surface-container-high">
                {(project.data.thumbnail ?? project.data.heroImage) ? (
                  <>
                    <SmartImage
                      src={project.data.thumbnail ?? project.data.heroImage!}
                      alt=""
                      class="absolute inset-0 w-full h-full object-cover scale-150 blur-3xl saturate-150"
                      sizes="200px"
                      width={200}
                      height={267}
                      quality={35}
                    />
                    <SmartImage
                      src={project.data.thumbnail ?? project.data.heroImage!}
                      alt={project.data.thumbnailAlt ?? project.data.heroImageAlt ?? project.data.title}
                      class="relative w-full h-full object-contain transition-transform duration-700 group-hover:scale-[1.03]"
                      sizes="(min-width: 768px) 33vw, 100vw"
                      width={600}
                      height={800}
                    />
                  </>
                ) : (
                  <div class="w-full h-full flex items-center justify-center bg-primary/5">
                    <Icon name="person" size={48} class="text-on-surface-variant/30" stroke={1.2} />
                  </div>
                )}
                <div class="absolute inset-0 bg-gradient-to-t from-on-surface/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              </div>
              <div class="relative p-6 md:p-8 flex flex-col gap-4 flex-1">
                <div class="typewriter-texture absolute inset-0 opacity-40 pointer-events-none"></div>
                <div class="relative flex items-start justify-between gap-3">
                  <span class="font-headline text-sm uppercase tracking-widest text-primary shrink-0">
                    {project.data.year}
                  </span>
                  {project.data.studio && (
                    <span class="font-headline text-xs uppercase tracking-widest text-on-surface-variant text-right line-clamp-1">
                      {project.data.studio}
                    </span>
                  )}
                </div>
                <div class="relative flex-1 space-y-3">
                  <h3 class="font-headline text-2xl font-bold text-on-surface group-hover:text-primary transition-colors">
                    {project.data.title}
                  </h3>
                  <p class="text-on-surface-variant text-sm leading-relaxed line-clamp-3">
                    {project.data.subtitle ?? project.data.description.slice(0, 140) + '…'}
                  </p>
                </div>
                <div class="relative flex items-center justify-between pt-4 border-t border-outline-variant/20">
                  <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">
                    {project.data.role}
                  </span>
                  <Icon name="arrow_forward" size={20} class="text-primary transition-transform group-hover:translate-x-1" />
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Filmography Table */}
    <section class="mb-16 reveal">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-headline text-2xl md:text-3xl font-bold text-on-surface">
          Vollständige Filmografie
        </h2>
        <span class="font-label text-xs uppercase tracking-widest text-on-surface-variant">
          {allProjects.length} Einträge
        </span>
      </div>

      <div class="bg-surface-container-low rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse min-w-[720px]">
            <thead>
              <tr class="bg-surface-container-highest">
                <th class="font-headline text-primary p-4 md:p-6 text-xs font-bold tracking-widest uppercase">Jahr</th>
                <th class="font-headline text-primary p-4 md:p-6 text-xs font-bold tracking-widest uppercase">Titel</th>
                <th class="font-headline text-primary p-4 md:p-6 text-xs font-bold tracking-widest uppercase">Genre</th>
                <th class="font-headline text-primary p-4 md:p-6 text-xs font-bold tracking-widest uppercase">Tätigkeit</th>
                <th class="font-headline text-primary p-4 md:p-6 text-xs font-bold tracking-widest uppercase text-right">Status</th>
              </tr>
            </thead>
            <tbody class="font-body text-on-surface">
              {allProjects.map((project, idx) => (
                <tr
                  class:list={[
                    'group transition-colors cursor-pointer',
                    idx % 2 === 0 ? 'bg-surface' : 'bg-surface-container-low',
                    'hover:bg-surface-container-high',
                  ]}
                  onclick={`location.href='/portfolio/${project.slug}/'`}
                >
                  <td class="p-4 md:p-6 font-medium align-middle">{project.data.year}</td>
                  <td class="p-4 md:p-6 align-middle">
                    <a
                      href={`/portfolio/${project.slug}/`}
                      class="text-lg md:text-xl font-semibold text-on-surface group-hover:text-primary transition-colors"
                    >
                      {project.data.title}
                    </a>
                    {project.data.subtitle && (
                      <p class="text-xs text-on-surface-variant mt-1 max-w-md">
                        {project.data.subtitle}
                      </p>
                    )}
                  </td>
                  <td class="p-4 md:p-6 align-middle whitespace-nowrap">
                    <span class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-xs font-semibold tracking-wide">
                      {project.data.genre}
                    </span>
                  </td>
                  <td class="p-4 md:p-6 align-middle text-on-surface-variant text-sm">
                    {project.data.role}
                  </td>
                  <td class="p-4 md:p-6 align-middle text-right">
                    <span class={`font-bold text-xs uppercase tracking-widest ${statusStyles[project.data.status]}`}>
                      {statusLabel[project.data.status]}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      {allProjects.length === 0 && (
        <div class="bg-surface-container-low rounded-lg p-16 text-center">
          <p class="font-headline text-lg text-on-surface-variant">
            Noch keine Projekte vorhanden.
          </p>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
