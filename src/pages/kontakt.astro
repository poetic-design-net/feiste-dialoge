---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const contact = await getEntry('pages', 'contact');
const hero = contact?.data.hero;
const postitText = contact?.data.postit;
const availability = contact?.data.availability ?? [];
const directContact = contact?.data.contact;

const toneClass: Record<string, string> = {
  busy: 'bg-error-container text-on-error-container',
  partial: 'bg-secondary-container text-on-secondary-container',
  open: 'bg-primary-fixed text-on-primary-fixed',
};
---

<BaseLayout
  title="Kontakt & Verfügbarkeit"
  description="Projekt anfragen, Verfügbarkeit prüfen, Kontakt aufnehmen — Florian Feiste, Dialogbuchautor und Dramaturg."
  active="contact"
>
  <div class="container-main py-16 md:py-24">
    {hero && (
      <section class="mb-16 md:mb-20 max-w-3xl">
        {hero.eyebrow && (
          <span class="font-headline text-sm uppercase tracking-widest text-primary">{hero.eyebrow}</span>
        )}
        <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05] mt-4">
          {hero.title}
        </h1>
        {hero.subtitle && (
          <p class="text-lg md:text-xl text-on-surface-variant leading-relaxed mt-6">{hero.subtitle}</p>
        )}
      </section>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 md:gap-12 items-start">
      <section class="lg:col-span-7">
        <form
          id="contact-form"
          class="relative bg-surface-container-low rounded-xl p-8 md:p-10 space-y-6"
          novalidate
        >
          <input type="hidden" name="bot-field" aria-hidden="true" tabindex="-1" autocomplete="off" class="sr-only" />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="block font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">Name</label>
              <input id="name" name="name" type="text" required class="w-full bg-surface-container-lowest border-b-2 border-outline/40 focus:border-primary focus:outline-none px-4 py-3 rounded-t text-on-surface transition-colors" placeholder="Ihr Name" />
            </div>
            <div class="space-y-2">
              <label for="email" class="block font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">E-Mail</label>
              <input id="email" name="email" type="email" required class="w-full bg-surface-container-lowest border-b-2 border-outline/40 focus:border-primary focus:outline-none px-4 py-3 rounded-t text-on-surface transition-colors" placeholder="ihre@email.de" />
            </div>
          </div>

          <div class="space-y-2">
            <label for="topic" class="block font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">Thema</label>
            <select id="topic" name="topic" class="w-full bg-surface-container-lowest border-b-2 border-outline/40 focus:border-primary focus:outline-none px-4 py-3 rounded-t text-on-surface transition-colors">
              <option>Projektanfrage</option>
              <option>Stoffberatung / Script-Doctoring</option>
              <option>Dialogbuch / Synchron</option>
              <option>Sonstiges</option>
            </select>
          </div>

          <div class="space-y-2">
            <label for="message" class="block font-label text-xs uppercase tracking-widest text-on-surface-variant font-bold">Nachricht</label>
            <textarea id="message" name="message" rows="6" required class="w-full bg-surface-container-lowest border-b-2 border-outline/40 focus:border-primary focus:outline-none px-4 py-3 rounded-t text-on-surface transition-colors resize-none" placeholder="Erzählen Sie mir kurz vom Projekt oder der Idee…"></textarea>
          </div>

          <div class="flex items-start gap-3 pt-2">
            <input id="privacy" name="privacy" type="checkbox" required class="mt-1 w-4 h-4 rounded border-outline text-primary focus:ring-primary" />
            <label for="privacy" class="text-sm text-on-surface-variant leading-relaxed">
              Ich habe die <a href="/datenschutz/" class="text-primary hover:underline">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Angaben zu.
            </label>
          </div>

          <div
            id="contact-error"
            role="alert"
            class="hidden text-sm text-error bg-error-container/40 border border-error/20 rounded-lg px-4 py-3"
          ></div>

          <button type="submit" id="contact-submit" class="btn-gradient w-full justify-center py-4 disabled:opacity-70 disabled:cursor-not-allowed">
            <span class="submit-label">Nachricht senden</span>
            <span class="submit-loading hidden">Wird gesendet…</span>
            <span class="material-symbols-outlined submit-icon">send</span>
          </button>
        </form>

        <div
          id="contact-success"
          class="hidden bg-surface-container-low rounded-xl p-10 md:p-12 text-center"
        >
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary-fixed mb-6">
            <span class="material-symbols-outlined text-primary text-4xl">check_circle</span>
          </div>
          <h2 class="font-headline text-3xl md:text-4xl font-bold tracking-tight mb-4">
            Angekommen.
          </h2>
          <p class="text-on-surface-variant leading-relaxed max-w-md mx-auto">
            Danke für Ihre Nachricht. Ich melde mich in der Regel innerhalb von zwei Werktagen per E-Mail zurück.
          </p>
        </div>

        <script is:inline>
          (function () {
            const init = () => {
              const form = document.getElementById('contact-form');
              const success = document.getElementById('contact-success');
              const errorBox = document.getElementById('contact-error');
              const submitBtn = document.getElementById('contact-submit');
              if (!form || !success || !errorBox || !submitBtn) return;
              if (form.dataset.bound === '1') return;
              form.dataset.bound = '1';

              const setLoading = (loading) => {
                submitBtn.disabled = loading;
                submitBtn.querySelector('.submit-label').classList.toggle('hidden', loading);
                submitBtn.querySelector('.submit-loading').classList.toggle('hidden', !loading);
                submitBtn.querySelector('.submit-icon').classList.toggle('hidden', loading);
              };

              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                errorBox.classList.add('hidden');

                const data = Object.fromEntries(new FormData(form).entries());
                data.privacy = form.querySelector('#privacy').checked;

                setLoading(true);
                try {
                  const res = await fetch('/api/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data),
                  });
                  const json = await res.json().catch(() => ({}));
                  if (!res.ok || !json.ok) {
                    throw new Error(json.error || 'Senden fehlgeschlagen. Bitte später erneut versuchen.');
                  }
                  form.classList.add('hidden');
                  success.classList.remove('hidden');
                  success.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } catch (err) {
                  errorBox.textContent = err?.message || 'Unerwarteter Fehler.';
                  errorBox.classList.remove('hidden');
                } finally {
                  setLoading(false);
                }
              });
            };

            init();
            document.addEventListener('astro:page-load', init);
          })();
        </script>
      </section>

      <aside class="lg:col-span-5 space-y-8">
        {postitText && (
          <div class="relative">
            <div class="bg-postit-yellow p-8 shadow-postit-lg relative" style="transform: rotate(-1.5deg);">
              <div class="absolute top-0 left-0 right-0 h-6 bg-on-surface/[0.03]"></div>
              <p class="font-handwriting text-xl md:text-2xl text-on-surface leading-relaxed whitespace-pre-line">
                {postitText}
              </p>
            </div>
          </div>
        )}

        {availability.length > 0 && (
          <section class="bg-surface-container-low rounded-lg p-8">
            <h2 class="font-headline text-xl text-primary mb-6">Verfügbarkeit</h2>
            <ul class="space-y-4">
              {availability.map((a) => (
                <li class="flex items-center justify-between gap-4">
                  <span class="font-headline text-lg">{a.period}</span>
                  <span class={`px-3 py-1 rounded-full text-xs font-semibold tracking-wide ${toneClass[a.tone]}`}>
                    {a.status}
                  </span>
                </li>
              ))}
            </ul>
          </section>
        )}

        {directContact && (directContact.email || directContact.phone) && (
          <section class="bg-matcha-gradient rounded-lg p-8 text-on-primary">
            <p class="font-headline text-sm uppercase tracking-widest text-on-primary/80 mb-4">Direktkontakt</p>
            <div class="space-y-3">
              {directContact.email && (
                <a href={`mailto:${directContact.email}`} class="flex items-center gap-3 hover:underline">
                  <span class="material-symbols-outlined">mail</span>
                  {directContact.email}
                </a>
              )}
              {directContact.phone && (
                <a href={`tel:${directContact.phone.replace(/\s/g, '')}`} class="flex items-center gap-3 hover:underline">
                  <span class="material-symbols-outlined">call</span>
                  {directContact.phone}
                </a>
              )}
            </div>
          </section>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>
