---
import BaseLayout from '@layouts/BaseLayout.astro';

const timeline = [
  {
    year: '2024',
    title: 'Dramaturgie — „Echo der Stille"',
    description: 'Preisgekrönter Dokumentarfilm. Strukturierung von 80h Interview-Material zu einer dreispurigen Erzählung.',
  },
  {
    year: '2023',
    title: 'Drehbuch — „Schatten über Berlin"',
    description: 'Noir-Thriller im Berlin der späten 60er-Jahre. Zwei Jahre Entwicklungsarbeit in enger Abstimmung mit Regie und Fachberatung.',
  },
  {
    year: '2022',
    title: 'Dialogbuch — „Der letzte Tastenanschlag"',
    description: 'Lippensynchrone Adaption eines englischsprachigen Kammerspiels ins Deutsche.',
  },
  {
    year: '2019 — 2022',
    title: 'Script-Doctoring & Stoffberatung',
    description: 'Beratung bei diversen Serien- und Spielfilmproduktionen (Krimi, Drama, Arthouse).',
  },
];

const principles = [
  {
    icon: 'record_voice_over',
    title: 'Jede Figur hat ihre eigene Stimme',
    description: 'Dialog ist mehr als Information. Dialog ist Charakter, Rhythmus, Subtext — und manchmal das, was nicht gesagt wird.',
  },
  {
    icon: 'trending_flat',
    title: 'Struktur vor Stil',
    description: 'Die beste Zeile trägt nichts, wenn der Bogen nicht stimmt. Ich denke immer in Szene, Akt und Gesamterzählung.',
  },
  {
    icon: 'handshake',
    title: 'Kollaboration auf Augenhöhe',
    description: 'Regie, Produktion, Lektorat — gute Arbeit entsteht im Dialog. Ich höre zu, bevor ich schreibe.',
  },
];
---

<BaseLayout
  title="Über mich"
  description="Florian Feiste — Dialogbuchautor, Dramaturg und Drehbuchautor. Hintergrund, Ansatz und Werdegang."
  active="about"
>
  <div class="container-main py-16 md:py-24">
    <!-- Hero -->
    <section class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-16 items-center mb-20 md:mb-32">
      <div class="md:col-span-7 space-y-6 order-2 md:order-1">
        <span class="font-headline text-sm uppercase tracking-widest text-primary">Über mich</span>
        <h1 class="font-headline text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.05]">
          Florian Feiste.<br/>
          <span class="text-primary">Worte als Handwerk.</span>
        </h1>
        <div class="text-lg md:text-xl text-on-surface-variant leading-relaxed space-y-4 max-w-xl">
          <p>
            Seit über zehn Jahren arbeite ich an Dialogen, Drehbüchern und dramaturgischen Konzepten — für Kino, Fernsehen und Streaming.
          </p>
          <p>
            Mein Ansatz: Genaues Hinhören. Figuren entstehen aus ihrer Sprache. Szenen entstehen aus Subtext. Und die besten Geschichten sind die, bei denen wir am Ende glauben, die Figuren seien uns schon lange bekannt.
          </p>
        </div>
      </div>

      <div class="md:col-span-5 relative order-1 md:order-2">
        <div class="rounded-xl overflow-hidden aspect-[4/5] bg-surface-container-high relative">
          <div class="w-full h-full flex items-center justify-center bg-matcha-gradient/10">
            <span class="material-symbols-outlined text-on-surface-variant/30" style="font-size: 120px;">person</span>
          </div>
        </div>
        <div class="absolute -bottom-4 -right-4 bg-surface-container-lowest shadow-ambient rounded-lg p-6 max-w-[220px]">
          <p class="font-headline text-xs uppercase tracking-widest text-primary mb-2">Basis</p>
          <p class="font-body text-sm text-on-surface">Berlin &amp; Hamburg<br/>Arbeiten europaweit.</p>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section class="mb-20 md:mb-32">
      <div class="text-center mb-12 md:mb-16 space-y-3 max-w-2xl mx-auto">
        <span class="font-headline text-sm uppercase tracking-widest text-primary">Arbeitsweise</span>
        <h2 class="section-title">Drei Grundüberzeugungen.</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {principles.map((p) => (
          <div class="bg-surface-container-low rounded-lg p-8 space-y-5">
            <div class="w-14 h-14 bg-primary-fixed flex items-center justify-center rounded-full">
              <span class="material-symbols-outlined text-primary text-3xl">{p.icon}</span>
            </div>
            <h3 class="font-headline text-2xl font-bold text-on-surface leading-tight">{p.title}</h3>
            <p class="text-on-surface-variant leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Timeline -->
    <section class="mb-20">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
        <div class="md:col-span-4">
          <span class="font-headline text-sm uppercase tracking-widest text-primary">Werdegang</span>
          <h2 class="section-title mt-3">Auswahl.</h2>
        </div>
        <div class="md:col-span-8 md:pt-4">
          <p class="text-on-surface-variant text-lg italic leading-relaxed">
            Eine kleine Auswahl der Stationen der letzten Jahre — keine vollständige Chronik, eher ein Streifzug durch die Projekte, die geprägt haben.
          </p>
        </div>
      </div>

      <ol class="relative space-y-10 md:space-y-0">
        {timeline.map((entry) => (
          <li class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-12 md:py-8 md:border-b md:border-outline-variant/20">
            <div class="md:col-span-3">
              <span class="font-headline text-2xl md:text-3xl font-bold text-primary">{entry.year}</span>
            </div>
            <div class="md:col-span-9 space-y-2">
              <h3 class="font-headline text-xl md:text-2xl font-bold text-on-surface">{entry.title}</h3>
              <p class="text-on-surface-variant leading-relaxed">{entry.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- CTA -->
    <section class="bg-surface-container-low rounded-xl p-10 md:p-16 text-center">
      <h2 class="font-headline text-3xl md:text-4xl font-bold mb-4">
        Lust auf ein Gespräch?
      </h2>
      <p class="text-on-surface-variant max-w-xl mx-auto mb-8 text-lg">
        Ob Stoffentwicklung, Synchron oder Dramaturgie — ich freue mich auf Ihre Nachricht.
      </p>
      <a href="/kontakt/" class="btn-gradient">
        Kontakt aufnehmen
        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
      </a>
    </section>
  </div>
</BaseLayout>
